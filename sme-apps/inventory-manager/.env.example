# ── Postgres ─────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=inventory

# ── Backend (Auth0) ───────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://inventory-api
# M2M app credentials for Auth0 Management API (role sync)
AUTH0_MGMT_CLIENT_ID=your-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-m2m-client-secret

# ── Frontend (Auth0) ──────────────────────────────────────────────
# AUTH0_SECRET: run `openssl rand -hex 32` to generate
AUTH0_SECRET=replace-with-32-byte-hex-secret
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret

# ── Inter-service ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
